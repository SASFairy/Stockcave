# Network Port Configuration (Docker host port mapping, default is 3000)
PORT=3000

# Database Configuration
DATABASE_URL="file:./dev.db"

# Security & Encryption (AES-256-GCM requires a 32-byte secret)
# You can generate a secure hex key using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET="replace_with_a_secure_32_byte_hex_string_in_production"

# Group Portal Authentication PIN
GROUP_PIN="1234"

# Settings Admin Password
ADMIN_PASSWORD="admin"

# Session Secret (for signed cookies)
SESSION_SECRET="replace_with_a_secure_session_secret"
